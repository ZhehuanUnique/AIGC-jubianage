# 即梦 AI (火山引擎) API 配置示例
# 复制此文件为 .env 并填入您的实际配置

# 火山引擎 API 基础地址
JIMENG_API_ENDPOINT=https://visual.volcengineapi.com

# 火山引擎 Access Key ID
VOLCENGINE_ACCESS_KEY_ID=your_access_key_id_here

# 火山引擎 Secret Access Key (Base64 编码)
VOLCENGINE_SECRET_ACCESS_KEY=your_secret_access_key_here

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 其他 API 配置（可选）
API_KEY=
SEEDANCE_API_ENDPOINT=

# Supabase 数据库配置
# 获取方式：Supabase Dashboard → Project Settings → Database → Connection string
# 格式：postgresql://postgres:[PASSWORD]@[PROJECT-REF].supabase.co:5432/postgres
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@[PROJECT-REF].supabase.co:5432/postgres

# 默认用户 API Key（单用户模式）
DEFAULT_API_KEY=default_key

# 对象存储配置（二选一）
# 方式1：阿里云 OSS
STORAGE_TYPE=aliyun_oss
ALIYUN_OSS_ACCESS_KEY_ID=your_access_key_id
ALIYUN_OSS_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_OSS_BUCKET_NAME=your_bucket_name
ALIYUN_OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
ALIYUN_OSS_BUCKET_DOMAIN=your-cdn-domain.com  # CDN域名（可选）

# 方式2：亚马逊 S3
# STORAGE_TYPE=s3
# AWS_ACCESS_KEY_ID=your_access_key_id
# AWS_SECRET_ACCESS_KEY=your_secret_access_key
# AWS_S3_BUCKET_NAME=your_bucket_name
# AWS_S3_REGION=us-east-1

# Sora 2 API 配置
# 国内直连：https://grsai.dakka.com.cn
# 海外：根据文档填写
SORA2_API_HOST=https://grsai.dakka.com.cn
SORA2_API_KEY=your_sora2_api_key_here

# Seedance API 配置
# 创建任务 API：https://api.302.ai/doubao/doubao-seedance
# 查询任务 API：https://ark.cn-beijing.volces.com/api/v3/contents/generations/tasks/{id}
SEEDANCE_API_HOST=https://api.302ai.cn  # 创建任务 API Host（默认国内中转）
SEEDANCE_API_KEY=your_seedance_api_key_here  # ARK_API_KEY
SEEDANCE_QUERY_HOST=https://ark.cn-beijing.volces.com  # 查询任务 API Host
SEEDANCE_MODEL=doubao-seedance-1-5-pro-251215  # 默认使用 pro 版本（支持音频），也可使用 lite 版本：doubao-seedance-1-0-lite-i2v-250428

# 阿里云百炼平台 API 配置
# 用于 wan2.2-i2v-flash 等模型
# 获取方式：登录阿里云百炼平台，在 API 密钥管理页面创建
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/api/v1

